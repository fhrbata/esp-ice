# ---------------------------------------------------------------------------
# llvm-mingw — shared by the three windows-* targets below.
# ---------------------------------------------------------------------------

LLVM_MINGW_URL  := https://github.com/mstorsjo/llvm-mingw/releases/download/20251216/llvm-mingw-20251216-ucrt-ubuntu-22.04-x86_64.tar.xz
LLVM_MINGW_DIR  := $(CURDIR)/toolchains/llvm-mingw
LLVM_MINGW_DONE := $(LLVM_MINGW_DIR)/.done

$(LLVM_MINGW_DONE): Makefile.toolchain
	@rm -rf $(LLVM_MINGW_DIR)
	@echo "Downloading and installing llvm-mingw toolchain..." >&2
	@mkdir -p $(LLVM_MINGW_DIR)
	@curl -fL $(LLVM_MINGW_URL) | tar -xJ -C $(LLVM_MINGW_DIR) --strip-components=1
	@touch $(LLVM_MINGW_DONE)

# ---------------------------------------------------------------------------
# windows-amd64
# ---------------------------------------------------------------------------

WINDOWS_AMD64_DIR := $(CURDIR)/toolchains/windows-amd64

windows-amd64: $(WINDOWS_AMD64_DIR)
	@echo "export PATH=\"$(WINDOWS_AMD64_DIR)/bin:\$$PATH\""

$(WINDOWS_AMD64_DIR): $(LLVM_MINGW_DONE)
	@rm -f $@
	@ln -s llvm-mingw $@

# ---------------------------------------------------------------------------
# windows-i386
# ---------------------------------------------------------------------------

WINDOWS_I386_DIR := $(CURDIR)/toolchains/windows-i386

windows-i386: $(WINDOWS_I386_DIR)
	@echo "export PATH=\"$(WINDOWS_I386_DIR)/bin:\$$PATH\""

$(WINDOWS_I386_DIR): $(LLVM_MINGW_DONE)
	@rm -f $@
	@ln -s llvm-mingw $@

