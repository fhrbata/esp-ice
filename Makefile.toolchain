# Makefile.toolchain
#
# Downloads prebuilt cross-compilation toolchains under toolchains/ and
# prints an `export PATH=…` line on stdout so it can be eval-ed:
#
#     eval "$(make -f Makefile.toolchain linux-arm64)"
#     make STATIC=1 CC=aarch64-linux-musl-gcc targz-pkg
#
# Run without arguments (or with `help`) for the catalogue of targets.
#
# musl.cc is unreachable from GitHub Actions' Azure IP ranges, so we
# fetch the musl-based toolchains through the musl-cc/musl.cc GitHub
# mirror — byte-perfect and on GitHub's CDN.

.DEFAULT_GOAL := help

.PHONY: help clean \
	linux-amd64 linux-arm64 linux-armel linux-armhf \
	linux-i386 linux-ppc64el linux-riscv64 linux-s390x \
	windows-amd64 windows-i386 windows-arm64

help:
	@echo 'Makefile.toolchain — fetch prebuilt cross-compilation toolchains'
	@echo ''
	@echo 'USAGE:'
	@echo '    eval "$$(make -f Makefile.toolchain <target>)"'
	@echo '    make STATIC=1 CC=<compiler> targz-pkg'
	@echo ''
	@echo 'LINUX TARGETS (musl.cc, gcc):'
	@echo '    linux-amd64        CC=x86_64-linux-musl-gcc'
	@echo '    linux-arm64        CC=aarch64-linux-musl-gcc'
	@echo '    linux-armel        CC=arm-linux-musleabi-gcc'
	@echo '    linux-armhf        CC=arm-linux-musleabihf-gcc'
	@echo '    linux-i386         CC=i686-linux-musl-gcc'
	@echo '    linux-ppc64el      CC=powerpc64le-linux-musl-gcc'
	@echo '    linux-riscv64      CC=riscv64-linux-musl-gcc'
	@echo '    linux-s390x        CC=s390x-linux-musl-gcc'
	@echo ''
	@echo 'WINDOWS TARGETS (llvm-mingw, gcc/clang):'
	@echo '    windows-amd64      CC=x86_64-w64-mingw32-gcc'
	@echo '    windows-i386       CC=i686-w64-mingw32-gcc'
	@echo '    windows-arm64      CC=aarch64-w64-mingw32-gcc'

clean:
	@rm -rf $(CURDIR)/toolchains

# ---------------------------------------------------------------------------
# linux-amd64
# ---------------------------------------------------------------------------

LINUX_AMD64_URL  := https://github.com/musl-cc/musl.cc/releases/download/v0.0.1/x86_64-linux-musl-cross.tgz
LINUX_AMD64_DIR  := $(CURDIR)/toolchains/linux-amd64
LINUX_AMD64_DONE := $(LINUX_AMD64_DIR)/.done

linux-amd64: $(LINUX_AMD64_DONE)
	@echo "export PATH=\"$(LINUX_AMD64_DIR)/bin:\$$PATH\""

$(LINUX_AMD64_DONE): Makefile.toolchain
	@rm -rf $(LINUX_AMD64_DIR)
	@echo "Downloading and installing linux-amd64 toolchain..." >&2
	@mkdir -p $(LINUX_AMD64_DIR)
	@curl -fL $(LINUX_AMD64_URL) | tar -xz -C $(LINUX_AMD64_DIR) --strip-components=1
	@touch $(LINUX_AMD64_DONE)

