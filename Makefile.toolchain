windows-arm64: $(WINDOWS_ARM64_DIR)
	@echo "export PATH=\"$(WINDOWS_ARM64_DIR)/bin:\$$PATH\""

$(WINDOWS_ARM64_DIR): $(LLVM_MINGW_DONE)
	@rm -f $@
	@ln -s llvm-mingw $@
